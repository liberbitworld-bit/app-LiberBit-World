// LiberBit World — Debate Module v1.1 (debate.js)
// Canales de debate por propuesta de gobernanza via Nostr kind:1

const LBW_Debate = (() => {
    'use strict';

    const _messages      = {};
    const _subscriptions = {};
    const _callbacks     = {};

    function _tag(dTag) { return 'lbw-debate-' + dTag; }

    function _ensureCache(dTag) {
        if (!_messages[dTag]) _messages[dTag] = new Map();
    }

    function _normalize(event) {
        var replyTag = null, rootTag = null;
        for (var i = 0; i < event.tags.length; i++) {
            var t = event.tags[i];
            if (t[0] === 'e' && t[3] === 'reply') replyTag = t;
            if (t[0] === 'e' && t[3] === 'root')  rootTag  = t;
        }
        return {
            id:        event.id,
            pubkey:    event.pubkey,
            content:   event.content,
            createdAt: event.created_at,
            replyTo:   replyTag ? replyTag[1] : null,
            rootId:    rootTag  ? rootTag[1]  : null,
            tags:      event.tags
        };
    }

    function subscribeDebate(proposalDTag, onMessage) {
        _ensureCache(proposalDTag);

        if (!_callbacks[proposalDTag]) _callbacks[proposalDTag] = [];
        if (onMessage) _callbacks[proposalDTag].push(onMessage);

        if (_subscriptions[proposalDTag]) {
            var cached = getMessages(proposalDTag);
            for (var i = 0; i < cached.length; i++) {
                if (onMessage) onMessage(cached[i], 'cached');
            }
            return;
        }

        var nostr = window.LBW_Nostr;
        if (!nostr || typeof nostr.subscribe !== 'function') {
            console.warn('[Debate] LBW_Nostr no disponible');
            return;
        }

        var filter = { kinds: [1], '#t': [_tag(proposalDTag)], limit: 200 };

        var sub = nostr.subscribe(
            [filter],
            function(event) {
                _ensureCache(proposalDTag);
                var msg = _normalize(event);
                if (!_messages[proposalDTag].has(msg.id)) {
                    _messages[proposalDTag].set(msg.id, msg);
                    var cbs = _callbacks[proposalDTag] || [];
                    for (var i = 0; i < cbs.length; i++) cbs[i](msg, 'new');
                }
            },
            function() {
                var cbs = _callbacks[proposalDTag] || [];
                for (var i = 0; i < cbs.length; i++) cbs[i](null, 'eose');
            }
        );

        _subscriptions[proposalDTag] = sub;
    }

    function unsubscribeDebate(proposalDTag) {
        if (_subscriptions[proposalDTag]) {
            try {
                var s = _subscriptions[proposalDTag];
                if (s && typeof s.unsub === 'function') s.unsub();
            } catch(e) {}
            delete _subscriptions[proposalDTag];
        }
        delete _callbacks[proposalDTag];
    }

    async function publishDebateMessage(proposalDTag, content, replyToEventId) {
        var nostr = window.LBW_Nostr;
        if (!nostr || !nostr.isLoggedIn()) {
            throw new Error('Necesitas estar conectado con Nostr para participar.');
        }
        if (!content || !content.trim()) {
            throw new Error('El mensaje no puede estar vacío.');
        }
        if (content.trim().length > 2000) {
            throw new Error('Máximo 2.000 caracteres.');
        }

        var tags = [
            ['t', 'lbw-debate'],
            ['t', _tag(proposalDTag)]
        ];

        if (replyToEventId) {
            tags.push(['e', replyToEventId, '', 'reply']);
        }

        await nostr.publishEvent({ kind: 1, content: content.trim(), tags: tags });
    }

    function getMessages(proposalDTag) {
        _ensureCache(proposalDTag);
        return Array.from(_messages[proposalDTag].values())
            .sort(function(a, b) { return a.createdAt - b.createdAt; });
    }

    function getMessageCount(proposalDTag) {
        if (!_messages[proposalDTag]) return 0;
        return _messages[proposalDTag].size;
    }

    function clearCache(proposalDTag) {
        delete _messages[proposalDTag];
    }

    return {
        subscribeDebate:      subscribeDebate,
        unsubscribeDebate:    unsubscribeDebate,
        publishDebateMessage: publishDebateMessage,
        getMessages:          getMessages,
        getMessageCount:      getMessageCount,
        clearCache:           clearCache
    };

})();

window.LBW_Debate = LBW_Debate;
